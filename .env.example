# ---- پایگاه داده (PostgreSQL) ----
# رشته‌ی اتصال Drizzle/pg
DATABASE_URL="postgresql://user:password@localhost:5432/qafaseh"

# ---- احراز هویت ----
# کلید امضای JWT — یک مقدار تصادفی و امن (حداقل ۳۲ کاراکتر).
# تولید نمونه:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret-value"

# ---- ادمین ----
# ایمیل‌هایی که به‌صورت خودکار دسترسی ادمین دارند (با کاما جدا شوند).
# برای راه‌اندازی اولین ادمین بدون ویرایش مستقیم دیتابیس کاربرد دارد.
# جایگزین/مکمل: ستون role=ADMIN روی کاربر در دیتابیس.
ADMIN_EMAILS="you@example.com"

# ---- آدرس اپ ----
# آدرس نهایی پروداکشن. این مقدار مبنای canonical URL، sitemap، OpenGraph و لینک‌های ایمیل است.
APP_URL="http://localhost:3000"
# برای استفاده‌ی کلاینت‌ساید در صورت نیاز
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# سازگاری با کدهای قدیمی‌تر متادیتا
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
PORT="3005"

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# اگر خالی باشد از NEXT_PUBLIC_APP_URL + /api/auth/google/callback ساخته می‌شود
GOOGLE_REDIRECT_URI=""

# ---- آپلود و ذخیره‌سازی ----
# local فقط در توسعه کاربرد دارد؛ در production همیشه S3 استفاده می‌شود.
UPLOAD_DRIVER="local"
# fallback محلی فقط در توسعه فعال است و در production نادیده گرفته می‌شود.
UPLOAD_LOCAL_FALLBACK="true"
# محدودیت حجم فایل آپلودی بر حسب کیلوبایت
UPLOAD_MAX_FILE_KB="500"

# ---- S3 / Arvan Object Storage ----
# در production آپلود همیشه S3 است؛ local فقط برای توسعه قابل استفاده است.
# این نام‌ها دقیق‌اند؛ متغیرهای ترکیب‌شده/غلط مانند
# S3_SECRET_ACCESS_KEYS3_PUBLIC_BASE_URL خوانده نمی‌شوند.
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""
# اختیاری است (برای Arvan مقدار پیش‌فرض auto استفاده می‌شود).
S3_REGION=""

# ---- ایمیل (Mailerino SMTP) ----
# رمز عبور را فقط در محیط اجرا/Coolify وارد کنید؛ هرگز آن را commit نکنید.
SMTP_HOST="smtp.maileronline.com"
SMTP_PORT="587"
SMTP_USER="varmanliamirhosein@gmail.com"
SMTP_PASSWORD=""
MAIL_FROM="noreply@qafasehman.ir"
# فقط برای توسعه محلی بدون SMTP: ارسال را رد می‌کند و کد در پاسخ توسعه برمی‌گردد.
EMAIL_MODE="dev"
EMAIL_DEV_MODE="true"

# ---- اختیاری / دیباگ ----
DEBUG_LIBRARY_ROUTE="0"
