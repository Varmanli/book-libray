{
  "name": "book-libray",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "start:next": "next start",
    "prestart:prod": "node scripts/prestart-production.mjs",
    "start:prod": "npm run prestart:prod && npm run start:next",
    "lint": "eslint",
    "test": "tsx --test --test-concurrency=1 lib/**/*.test.ts",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:history:inspect": "node scripts/inspect-drizzle-migration-history.mjs",
    "db:prod:repair": "node scripts/prod-db-repair.mjs",
    "migrate:favicon": "tsx --env-file=.env scripts/migrate-local-favicon-to-s3.ts",
    "backfill:usernames": "tsx scripts/backfill-usernames.ts",
    "backfill:catalog-public": "tsx --env-file=.env scripts/backfill-catalog-public-books.ts",
    "db:apply:blog": "tsx --env-file=.env scripts/apply-blog-posts.ts",
    "db:apply:blog-categories": "tsx --env-file=.env scripts/apply-blog-categories.ts",
    "db:apply:home-content": "tsx --env-file=.env scripts/apply-home-content-catalog.ts",
    "db:apply:external-links": "tsx --env-file=.env scripts/apply-book-external-links.ts",
    "db:apply:site-settings": "tsx --env-file=.env scripts/apply-site-settings.ts",
    "db:apply:static-pages": "tsx --env-file=.env scripts/apply-static-pages.ts",
    "featured:inspect": "tsx scripts/inspect-featured-book-integrity.ts",
    "featured:repair": "tsx scripts/repair-featured-book-integrity.ts",
    "featured:repair:dry": "tsx scripts/repair-featured-book-integrity.ts --dry-run",
    "primary-edition:inspect": "tsx --env-file=.env scripts/repair-primary-edition-integrity.ts",
    "primary-edition:repair": "tsx --env-file=.env scripts/repair-primary-edition-integrity.ts --apply",
    "repair:joined-genres": "tsx --env-file=.env scripts/repair-joined-genre-references.ts",
    "storage:check": "tsx --env-file=.env scripts/check-storage.ts",
    "storage:inspect-local-paths": "tsx --env-file=.env scripts/inspect-local-image-paths.ts"
  },
  "dependencies": {
    "@ghafaseh/iranketab-extractor": "file:packages/iranketab-extractor",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@hookform/resolvers": "^5.2.1",
    "@prisma/extension-accelerate": "^2.0.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-icons/all-files": "^4.1.0",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.7.0",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "embla-carousel-react": "^8.6.0",
    "isomorphic-dompurify": "^3.18.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.542.0",
    "next": "15.5.2",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "recharts": "^3.2.1",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "workbox-webpack-plugin": "^7.3.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/minimatch": "^6.0.0",
    "@types/next-pwa": "^5.6.9",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5"
  }
}
